# API
VITE_API_BASE_URL=https://hex-zone-server.onrender.com

# Anonymous guest /access flow
VITE_ANONYMOUS_ACCESS_PERMISSION_PATH=/api/access/permission
VITE_ACCESS_SESSION_URL_TEMPLATE=/api/access/session/{guest_id}

# Guest JWT exchange + guest-only API prefix (defaults shown)
VITE_GUEST_SESSION_EXCHANGE_URL=/api/access/guest-session
VITE_GUEST_API_BASE_PATH=/api/guest

# Member dashboard + Messages: list guest requests for a zone (default /api/access/guest-requests)
# VITE_ADMIN_GUEST_REQUESTS_LIST_URL=

# Optional overrides used elsewhere in the app
# VITE_GUEST_ACCESS_PERMISSION_PATH=
# VITE_GUEST_QR_TOKENS_BASE_PATH=
# VITE_GUEST_DEVICE_API_KEY=
